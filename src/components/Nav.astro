---
const links = [
  { href: "#about", label: "About" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#contact", label: "Contact" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md"
  style="background-color: color-mix(in srgb, var(--color-bg) 80%, transparent); border-bottom: 1px solid var(--color-border);"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-10">
    <div class="flex items-end" style="gap: 12px;">
      <a
        href="/"
        class="font-heading text-xl font-bold tracking-tight uppercase"
        style="color: var(--color-text);"
      >
        Taja Vasilevich
      </a>
      <a
        href="/readme"
        style="font-family: monospace; font-size: 11px; color: #C0392B; opacity: 1; transition: opacity 150ms ease; text-decoration: none;"
        onmouseover="this.style.opacity='0.7'"
        onmouseout="this.style.opacity='1'"
      >/readme</a>
    </div>

    <div class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="font-body text-sm font-medium tracking-wide uppercase opacity-80 transition-opacity hover:opacity-100"
            style="color: var(--color-text);"
          >
            {link.label}
          </a>
        ))
      }
      <button
        id="theme-toggle"
        aria-label="Toggle light and dark mode"
        class="flex h-9 w-9 items-center justify-center rounded-full border transition-colors"
        style="border-color: var(--color-border); color: var(--color-text);"
      >
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-4 w-4"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="hidden h-4 w-4"
        >
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
        </svg>
      </button>
    </div>

    <button
      id="theme-toggle-mobile"
      aria-label="Toggle light and dark mode"
      class="flex h-9 w-9 items-center justify-center rounded-full border md:hidden"
      style="border-color: var(--color-border); color: var(--color-text);"
    >
      <svg
        id="icon-sun-mobile"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="h-4 w-4"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
        ></path>
      </svg>
      <svg
        id="icon-moon-mobile"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="hidden h-4 w-4"
      >
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
      </svg>
    </button>
  </nav>
</header>

<script>
  function applyTheme(theme: string) {
    if (theme === "light") {
      document.documentElement.setAttribute("data-theme", "light");
    } else {
      document.documentElement.removeAttribute("data-theme");
    }
    localStorage.setItem("theme", theme);
    const suns = document.querySelectorAll("#icon-sun, #icon-sun-mobile");
    const moons = document.querySelectorAll("#icon-moon, #icon-moon-mobile");
    suns.forEach((el) => el.classList.toggle("hidden", theme === "light"));
    moons.forEach((el) => el.classList.toggle("hidden", theme !== "light"));
  }

  function currentTheme() {
    return document.documentElement.getAttribute("data-theme") === "light"
      ? "light"
      : "dark";
  }

  function toggle() {
    applyTheme(currentTheme() === "light" ? "dark" : "light");
  }

  document.getElementById("theme-toggle")?.addEventListener("click", toggle);
  document
    .getElementById("theme-toggle-mobile")
    ?.addEventListener("click", toggle);

  applyTheme(currentTheme());
</script>
