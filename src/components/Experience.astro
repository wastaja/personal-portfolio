  },
  {
    title: "Business Data Analyst",
    company: "Just Join IT",
    period: "Apr 2024 — Oct 2025",
    bullets: [
      "Contributed data and analytics work to a new product launch that drove 45% of company annual revenue in its first full year; worked closely with Sales throughout pre-launch — analyzing customer needs alongside usage data to shape go-to-market decisions",
      "Designed and implemented churn calculation logic for a non-SaaS business model (package-based, no subscription) — defined churn criteria from scratch for clients with active packages expiring by usage or time, where standard SaaS metrics didn't apply",
      "Built Power BI dashboards for marketing, sales and operational reporting",
      "Developed early dbt models in Snowflake contributing to the company's analytical data layer",
      "Cohort analysis, funnel tracking and performance analysis to identify growth opportunities and improve campaign effectiveness",
      "Defined consistent business metrics and reporting logic across Sales and Marketing teams",
    ],
    stack: ["SQL", "Snowflake", "dbt", "Power BI", "Advanced Google Sheets"],
  },
  {
    title: "Response Rate Specialist",
    company: "Just Join IT",
    period: "Jul 2022 — Mar 2024",
    bullets: [
      "Built an internal data aggregation tool in Google Sheets consolidating large datasets from multiple job listing portals — designed filter-based interface enabling non-technical CS and Sales teams to independently extract statistics and insights without analyst support",
      "Designed and implemented a Twitter-based engagement strategy that increased response rates by 20% and engagement by 35%",
      "Analyzed campaign data and user engagement metrics to identify performance patterns and improve outreach effectiveness",
      "Built performance tracking dashboards in Google Sheets enabling ongoing monitoring and optimization of campaign results",
    ],
    stack: ["Google Analytics", "Google Sheets", "CRM"],
  },
];

const education = [
  {
    title: "Data Engineer Course",
    org: "Infoshare Academy",
    period: "In progress, exp. August 2026",
    stack: ["Python", "PySpark", "AWS", "ETL Workflows", "Apache Kafka", "Apache Airflow", "Docker", "Databricks", "DynamoDB"],
  },
  {
    title: "Management, Master's",
    org: "SWPS University Warsaw",
    period: "In progress, exp. 2027",
    stack: ["Data Analytics", "Finance & Business Law", "Social Psychology"],
  },
  {
    title: "Management & Leadership, Bachelor's",
